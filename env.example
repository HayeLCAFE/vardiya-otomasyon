# Sunucu (.env dosyasi olarak kopyalayin: cp env.example .env)
#
# 404: Apache istegi Node'a iletmiyorsa ana sayfa acilmaz.
# Cozum: deploy/apache-vardiya-proxy.conf ornegine gore reverse proxy.

NODE_ENV=production
PORT=5000

# Alt dizinde yayin (Apache ProxyPass /vardiya/ ...):
# PUBLIC_URL_PATH=/vardiya

# Apache / Nginx arkasında (HTTPS / dogru Host icin):
TRUST_PROXY=1

# CORS (farkli origin'den API cagrisi varsa)
APP_BASE_URL=
# CORS_ORIGINS=https://a.com,https://b.com

# MongoDB
# MONGODB_URI=mongodb://127.0.0.1:27017/vardiya

# Disariya acmak icin (VPS):
# BIND_HOST=0.0.0.0
