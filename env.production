# Sunucu dağıtımı için
NODE_ENV=production
PORT=5000

# Sunucuda subpath var
PUBLIC_URL_PATH=/vardiya

# Apache / Nginx arkasında
TRUST_PROXY=1

# CORS ayarları
APP_BASE_URL=
CORS_ORIGINS=https://maas.sinanacar.com.tr,https://mail.sinanacar.com.tr

# MongoDB (isteğe bağlı)
# MONGODB_URI=mongodb://127.0.0.1:27017/vardiya

# Sunucuda dışarıya açık
# BIND_HOST=0.0.0.0
